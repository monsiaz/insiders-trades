generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  amfToken    String   @unique
  description String?
  isin        String?
  market      String?
  // ── Financials (Yahoo timeseries, annual) ──────────────────────────────
  marketCap    BigInt?   // EUR
  sharesOut    BigInt?   // total shares outstanding
  revenue      BigInt?   // annual revenue
  netIncome    BigInt?   // annual net income
  ebitda       BigInt?   // annual EBITDA
  totalDebt    BigInt?   // total debt
  freeCashFlow BigInt?   // free cash flow
  grossProfit  BigInt?   // gross profit
  dilutedEps   Float?    // diluted EPS (annual)
  fiscalYearEnd String?  // "2025-03-31"
  financialsAt DateTime?
  // ── Valuation & analyst consensus (Yahoo quoteSummary) ─────────────────
  trailingPE   Float?    // trailing P/E
  forwardPE    Float?    // forward P/E
  priceToBook  Float?    // P/B ratio
  beta         Float?    // market beta
  debtToEquity Float?    // D/E ratio
  returnOnEquity Float?  // ROE
  returnOnAssets Float?  // ROA
  profitMargin Float?    // net margin
  heldByInsiders Float?  // % capital détenu par dirigeants
  heldByInstitutions Float? // % capital institutionnels
  shortRatio   Float?    // short interest ratio
  analystReco  String?   // "buy" | "hold" | "sell" | "strong_buy" | "underperform"
  analystScore Float?    // 1.0 (strong buy) → 5.0 (strong sell)
  targetMean   Float?    // objectif cours moyen analystes
  targetHigh   Float?    // objectif cours haut
  targetLow    Float?    // objectif cours bas
  numAnalysts  Int?      // nombre d'analystes
  currentPrice Float?    // dernier cours connu
  priceAt      DateTime? // when currentPrice / technicals were last fetched
  analystAt    DateTime? // when analyst data was last fetched
  // ── Technicals (Yahoo price meta) ──────────────────────────────────────
  fiftyTwoWeekHigh     Float?  // plus haut sur 52 semaines
  fiftyTwoWeekLow      Float?  // plus bas sur 52 semaines
  fiftyDayAverage      Float?  // moyenne mobile 50 jours
  twoHundredDayAverage Float?  // moyenne mobile 200 jours
  dividendYield        Float?  // taux de dividende (0–1, ex 0.032 = 3.2%)
  // ── Misc ───────────────────────────────────────────────────────────────
  marketCapAt  DateTime? // kept for compat
  yahooSymbol  String?   // cached Yahoo Finance symbol
  logoUrl      String?   // self-hosted logo (Vercel Blob CDN)
  logoSource   String?   // clearbit | google_favicon | scraped | openai | manual
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  declarations Declaration[]
  insiders     CompanyInsider[]
}

model Insider {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  gender    String?  // "M" | "F" | null (inferred from function title or name)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies    CompanyInsider[]
  declarations Declaration[]
}

model CompanyInsider {
  id         String   @id @default(cuid())
  companyId  String
  insiderId  String
  function   String?
  createdAt  DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insider  Insider @relation(fields: [insiderId], references: [id], onDelete: Cascade)

  @@unique([companyId, insiderId])
}

model Declaration {
  id          String          @id @default(cuid())
  amfId       String          @unique
  companyId   String
  insiderId   String?
  type        DeclarationType
  pubDate     DateTime
  link        String
  description String
  rawData     Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Trade detail fields (parsed from PDF)
  insiderName       String?
  insiderFunction   String?
  transactionNature String?
  instrumentType    String?
  isin              String?
  unitPrice         Float?
  volume            Float?
  totalAmount       Float?
  currency          String?
  transactionDate   DateTime?
  transactionVenue  String?
  pdfParsed         Boolean  @default(false)
  pdfUrl            String?

  // Signal & analytics fields
  pctOfMarketCap    Float?   // totalAmount / company.marketCap * 100
  pctOfInsiderFlow  Float?   // totalAmount / sum(all trades by this insider on this company) * 100
  insiderCumNet     Float?   // cumulative net position (buy - sell) by this insider on this company at this date
  signalScore       Float?   // composite signal score 0–100
  isCluster         Boolean  @default(false) // multiple insiders traded same week
  scoredAt          DateTime? // when signals were last computed

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insider       Insider?       @relation(fields: [insiderId], references: [id], onDelete: SetNull)
  backtestResult BacktestResult?

  @@index([companyId])
  @@index([insiderId])
  @@index([pubDate])
  @@index([type])
  @@index([isin])
  @@index([pdfParsed])
  @@index([signalScore])
  @@index([scoredAt])
}

model BacktestResult {
  id            String      @id @default(cuid())
  declarationId String      @unique
  declaration   Declaration @relation(fields: [declarationId], references: [id])
  direction     String      @default("BUY")  // BUY | SELL | OTHER
  priceAtTrade  Float?
  price30d      Float?
  price60d      Float?
  price90d      Float?
  price160d     Float?
  price365d     Float?
  price730d     Float?
  return30d     Float?
  return60d     Float?
  return90d     Float?
  return160d    Float?
  return365d    Float?
  return730d    Float?
  computedAt    DateTime    @default(now())
}

enum DeclarationType {
  DIRIGEANTS
  SEUILS
  PROSPECTUS
  OTHER
}

// ── User & Portfolio ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?   // display name (legacy / fallback)
  firstName     String?   // prénom
  lastName      String?   // nom de famille
  password      String
  emailVerified DateTime?
  verifyToken   String?   @unique
  resetToken    String?   @unique
  resetTokenExp DateTime?
  role          String    @default("user")   // "user" | "admin"
  isBanned      Boolean   @default(false)    // admin can revoke access
  bannedAt      DateTime?
  bannedReason  String?
  alertEnabled  Boolean   @default(true)
  lastAlertAt   DateTime?
  lastLoginAt   DateTime?
  // Portfolio cash balance (solde espèces du courtier)
  portfolioCash Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  positions PortfolioPosition[]
  alerts    UserAlert[]
}

model UserAlert {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  declarationId String?  // linked declaration if applicable
  type          String   // "GENERAL_SIGNAL" | "PORTFOLIO_MATCH" | "CLUSTER"
  title         String
  message       String
  sentAt        DateTime @default(now())
  readAt        DateTime?

  @@index([userId])
  @@index([declarationId])
}

model PortfolioPosition {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  isin         String?
  yahooSymbol  String?
  quantity     Float
  buyingPrice  Float    // average cost price per share
  currentPrice Float?
  lastUpdated  DateTime?

  // Computed
  totalInvested Float    // quantity * buyingPrice
  currentValue  Float?   // quantity * currentPrice
  pnl           Float?   // currentValue - totalInvested
  pnlPct        Float?   // pnl / totalInvested * 100

  // App signal flag
  fromApp      Boolean  @default(false)  // bought following InsiderTrades recommendation

  // Alerts
  alertBelow   Float?
  alertAbove   Float?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([isin])
}
