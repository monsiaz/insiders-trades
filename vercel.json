{
  "git": {
    "deploymentEnabled": false
  },
  "functions": {
    "src/app/api/cron/route.ts":           { "maxDuration": 300, "memory": 1024 },
    "src/app/api/backtest/compute/route.ts":{ "maxDuration": 300, "memory": 1024 },
    "src/app/api/translate-news/route.ts": { "maxDuration": 60,  "memory": 512  },
    "src/app/api/sync/route.ts":           { "maxDuration": 60,  "memory": 512  },
    "src/app/api/sync-latest/route.ts":    { "maxDuration": 60,  "memory": 512  },
    "src/app/api/enrich/route.ts":         { "maxDuration": 60,  "memory": 512  },
    "src/app/api/admin/ai/route.ts":       { "maxDuration": 120, "memory": 512  },
    "src/app/api/weekly-digest/route.ts":  { "maxDuration": 300, "memory": 1024 }
  },
  "crons": [
    {
      "path": "/api/sync-latest",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/enrich-mcap",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/backtest/compute",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/translate-news",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ]
}
